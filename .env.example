# =======================================================
# 🌐 XAMINIX PUBLIC ENVIRONMENT TEMPLATE
# =======================================================
# Copy this file to a new file named '.env.local' and
# fill in your secret keys. NEVER commit '.env.local' to Git!

# 🤖 Google Gemini AI API Configuration
# Get your free key from: https://aistudio.google.com/
GEMINI_API_KEY=""

# 🖼️ OCR Space API Configuration (For Text Extraction)
# Get your free key from: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=""

# ⚡ Supabase Cloud Database Configuration
# Get these from your Supabase project settings -> API page
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key" # Keep private, only for backend ingestion script/CLI