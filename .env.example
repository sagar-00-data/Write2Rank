# Environment Variables for AI Answer Checker
# Copy this file to .env.local and fill in your actual API keys

# Google Gemini API Key (Required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_google_gemini_api_key_here"

# OCR Space API Key (Required for OCR functionality)
# Get from: https://ocr.space/ocrapi
OCR_SPACE_API_KEY="your_ocr_space_api_key_here"

# Optional: Clerk Authentication (if implementing)
# Get from: https://dashboard.clerk.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."

# Development Settings (Optional)
# NODE_ENV="development"
# PORT=3000

# Note: Never commit .env.local to version control!
# This file (.env.example) is safe to commit as it contains only placeholders.